@page "/credits"
@layout EmptyLayout

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, .credits-root {
        background-color: #121212;
        color: #0f0;
        font-family: 'Courier New', 'Courier', monospace;
        font-size: 1.1rem;
        line-height: 1.5;
    }

    .credits-root {
        width: 100vw;
        min-height: 100vh;
        padding: 2rem 2.5rem;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
    }

    .bareiron-logo {
        display: block;
        width: 100%;
        max-width: 700px;
        height: auto;
        margin-bottom: 1.5rem;
    }

    .credits-root p, .credits-root .line {
        margin: 0.75rem 0;
        max-width: 900px;
    }

    .discord-badge {
        color: #0f0;
        background: transparent;
        border: 1px solid #0f0;
        padding: 0.2rem 1rem;
        display: inline-block;
        font-size: 1rem;
        font-family: 'Courier New', monospace;
        letter-spacing: 0.5px;
        margin: 0.5rem 0 1rem 0;
    }

    .discord-badge i {
        margin-right: 6px;
        color: #0f0;
    }

    .description, .warning {
        color: #0f0;
        opacity: 0.95;
    }

    .warning {
        color: #ffb86b;
        opacity: 1;
        margin-top: 1.5rem;
    }

    .warning i {
        margin-right: 8px;
        color: #ffb86b;
    }

    .credits-root strong {
        color: #fff;
        font-weight: 600;
    }

    .credits-root a {
        color: #0f0;
        text-decoration: none;
        border-bottom: 1px dotted #0f0;
    }

    .credits-root a:hover {
        border-bottom: 1px solid #fff;
        color: #fff;
    }

    .back-btn {
        margin-bottom: 1.5rem;
        color: #0f0;
        background: transparent;
        border: 1px solid #0f0;
        padding: 0.2rem 1rem;
        font-family: 'Courier New', monospace;
        font-size: 0.95rem;
        cursor: pointer;
        letter-spacing: 0.5px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .back-btn:hover {
        background: rgba(0, 255, 0, 0.08);
        color: #fff;
        border-color: #fff;
    }
</style>

<div class="credits-root">

    <a href="/" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Back</a>

